generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String   
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cupom {
  id          String   @id @default(cuid())
  codigo      String   @unique
  desconto    Float 
  ativo       Boolean  @default(true)
  vencimento  DateTime?
  createdAt   DateTime @default(now())
}

enum Role {
  MEMBER
  VIP
  STAFF
  ADMIN
}

model SitePin {
  id         Int      @id @default(autoincrement())
  playerNick String   @map("player_nick") @db.VarChar(16)
  pinCode    String   @unique @map("pin_code") @db.VarChar(6)
  createdAt  DateTime @default(now()) @map("created_at")
  expiresAt  DateTime @map("expires_at")

  @@map("site_pins")
}

model Produto {
  id          String   @id @default(cuid())
  ordem     Int      @default(0)
  nome        String
  descricao   String?
  preco       Float
  desconto    Int?     @default(0)
  imagem      String?
  categoria   String   // Ex: VIP, CASH, KEYS
  servidor    String   // Ex: SURVIVAL, SKYBLOCK, GLOBAL
  comandos    String[] // Array de comandos a serem executados no servidor
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  pedidos     PedidoItem[]
}

model Pedido {
  id            String   @id @default(cuid())
  playerNick    String
  gatewayRef    String?  @unique // ID da transação no Mercado Pago/Stripe
  status        StatusPedido @default(PENDENTE)
  total         Float
  metodoPagto   String?  // Ex: PIX, CARTAO
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  itens         PedidoItem[]
  entregas      FilaEntrega[]
}

model PedidoItem {
  id          String   @id @default(cuid())
  pedidoId    String
  produtoId   String
  quantidade  Int
  precoUnit   Float
  pedido      Pedido   @relation(fields: [pedidoId], references: [id])
  produto     Produto  @relation(fields: [produtoId], references: [id])
}

model FilaEntrega {
  id          Int      @id @default(autoincrement())
  pedidoId    String
  playerNick  String
  servidor    String
  comando     String
  status      StatusEntrega @default(AGUARDANDO)
  createdAt   DateTime @default(now())
  executedAt  DateTime?
  pedido      Pedido   @relation(fields: [pedidoId], references: [id])

  @@map("fila_entregas")
}

enum StatusPedido {
  PENDENTE
  APROVADO
  CANCELADO
  REEMBOLSADO
}

enum StatusEntrega {
  AGUARDANDO
  ENTREGUE
  FALHA
}

model Noticia {
  id        String   @id @default(cuid())
  titulo    String
  resumo    String
  conteudo  String   // Texto completo
  imagem    String?
  tag       String   @default("Novidade")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("noticias")
}